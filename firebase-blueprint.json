{
  "entities": {
    "log": {
      "title": "IP Log",
      "description": "A log of a user's name and IP address.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name entered by the user."
        },
        "ip": {
          "type": "string",
          "description": "The IP address of the user."
        },
        "city": {
          "type": "string",
          "description": "City of the user."
        },
        "region": {
          "type": "string",
          "description": "Region/State of the user."
        },
        "country": {
          "type": "string",
          "description": "Country of the user."
        },
        "org": {
          "type": "string",
          "description": "ISP or Organization of the user."
        },
        "latitude": {
          "type": "number",
          "description": "Latitude coordinate."
        },
        "longitude": {
          "type": "number",
          "description": "Longitude coordinate."
        },
        "postal": {
          "type": "string",
          "description": "Postal code."
        },
        "deviceInfo": {
          "type": "string",
          "description": "Device, OS, and Browser information."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the log was created."
        }
      },
      "required": ["name", "ip", "timestamp"]
    },
    "config": {
      "title": "Global Config",
      "description": "Global application configuration.",
      "type": "object",
      "properties": {
        "prankModeEnabled": {
          "type": "boolean",
          "description": "Whether the prank mode is active."
        },
        "redirectUrl": {
          "type": "string",
          "description": "The URL to redirect to when prank mode is disabled."
        }
      },
      "required": ["prankModeEnabled", "redirectUrl"]
    }
  },
  "firestore": {
    "/logs/{logId}": {
      "schema": "log",
      "description": "Collection of user IP logs."
    },
    "/config/global": {
      "schema": "config",
      "description": "Global configuration document."
    }
  }
}
