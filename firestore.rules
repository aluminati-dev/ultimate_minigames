rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: logs
    // Fields:
    //   - name: string (required)
    //   - ip: string (required)
    //   - city: string (optional)
    //   - region: string (optional)
    //   - country: string (optional)
    //   - org: string (optional)
    //   - latitude: number (optional)
    //   - longitude: number (optional)
    //   - postal: string (optional)
    //   - deviceInfo: string (optional)
    //   - timestamp: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "contact.myselfab@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidLog(data) {
      let requiredFields = ['name', 'ip', 'timestamp'];
      let allowedFields = ['name', 'ip', 'timestamp', 'city', 'region', 'country', 'org', 'latitude', 'longitude', 'postal', 'deviceInfo'];
      
      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.name is string && data.name.size() <= 200 &&
             data.ip is string && data.ip.size() <= 100 &&
             data.timestamp is timestamp &&
             (!('city' in data) || data.city is string) &&
             (!('region' in data) || data.region is string) &&
             (!('country' in data) || data.country is string) &&
             (!('org' in data) || data.org is string) &&
             (!('latitude' in data) || data.latitude is number) &&
             (!('longitude' in data) || data.longitude is number) &&
             (!('postal' in data) || data.postal is string) &&
             (!('deviceInfo' in data) || data.deviceInfo is string);
    }

    match /logs/{logId} {
      // Anyone can create a log (unauthenticated is allowed for the prank)
      allow create: if isValidLog(request.resource.data);
      
      // Only admin can read logs
      allow read: if isAdmin();
      
      // No updates or deletes allowed
      allow update, delete: if false;
    }

    match /config/global {
      // Anyone can read the config to know if they should be redirected
      allow read: if true;
      
      // Only admin can update the config
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
